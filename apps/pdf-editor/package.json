{
  "name": "pdf-editor",
  "version": "1.0.0",
  "description": "Next.js web app",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "node scripts/copy-pdf-worker.js && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "cd ../.. && vitest run",
    "db:generate": "cd ../../packages/database && pnpm db:generate",
    "db:migrate": "cd ../../packages/database && pnpm db:migrate",
    "db:push": "cd ../../packages/database && pnpm db:push",
    "db:studio": "cd ../../packages/database && pnpm db:studio",
    "type-check": "tsc --noEmit",
    "postinstall": "node scripts/copy-pdf-worker.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@polar-sh/better-auth": "^1.8.1",
    "@polar-sh/sdk": "^0.42.5",
    "@quick-pdfs/common": "workspace:*",
    "@quick-pdfs/database": "workspace:*",
    "@react-email/components": "^0.3.1",
    "@react-email/render": "^1.1.3",
    "@react-email/tailwind": "^1.2.1",
    "@t3-oss/env-nextjs": "^0.13.8",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/ms": "^2.1.0",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "better-auth": "^1.4.18",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.4",
    "eslint": "9.31.0",
    "eslint-config-next": "16.1.6",
    "idb": "^8.0.3",
    "lucide-react": "^0.564.0",
    "ms": "^2.1.3",
    "next": "16.1.6",
    "next-intl": "^4.8.1",
    "pdf-lib": "^1.17.1",
    "postcss": "8.5.6",
    "postgres": "^3.4.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",
    "react-pdf": "^10.3.0",
    "react-signature-canvas": "1.1.0-alpha.2",
    "resend": "^4.6.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.1",
